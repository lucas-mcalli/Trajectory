{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
, "src/contents"  ],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "paths": {
      "~*": [
        "./src/*"
      ]
    },
    "baseUrl": ".",
    "strict": true,
    "types": ["chrome"]
  }
}
